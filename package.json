    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "^5.55.5",
    "svelte-check": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.2.6"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.10",
